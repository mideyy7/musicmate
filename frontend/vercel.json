{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "REPLACE_WITH_RAILWAY_URL/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "REPLACE_WITH_RAILWAY_URL/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
